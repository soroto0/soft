# Скопируй этот файл в .env и впиши свои ключи. Файл .env никому не показывай.

# --- Amazon Polly (озвучка) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
POLLY_VOICE=Matthew
POLLY_ENGINE=neural

# --- Стоки ---
PEXELS_API_KEY=your_pexels_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# --- Whisper (субтитры) ---
WHISPER_MODEL=base.en

# --- Озвучка по умолчанию для CLI (pipeline.py) ---
# TTS_PROVIDER=edge — бесплатный Edge TTS без ключей, polly — Amazon Polly
TTS_PROVIDER=polly
EDGE_VOICE=en-US-GuyNeural

# --- Фоновая музыка (папка с лицензионными треками, необязательно) ---
# MUSIC_DIR=C:\Users\you\Music\background

# --- Gemini (тексты: черновик сценария, сцены, умные запросы, SEO;
#     запасной вариант для картинок, если Agnes не сработал) ---
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Agnes AI (картинки type: gen и в раскадровке;
#     запасной вариант для текстов, если Gemini не сработал) ---
AGNES_API_KEY=your_agnes_key_here
# AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_MODEL=agnes-2.0-flash
# AGNES_IMAGE_MODEL=   # пусто = автоопределение из списка моделей хаба

# --- VeoNonStop (видео Veo + картинки Banana) ---
VEO_API_KEY=your_veo_key_here
# VEO_BASE_URL=https://veononstop.org/api/v1
